# --- Database (native dev: docker 'db' is published on host port 5433) ---
DATABASE_URL=postgresql+asyncpg://yuno:yuno@localhost:5433/yuno
CHECKPOINT_DB_URI=postgresql://yuno:yuno@localhost:5433/yuno

# --- LLM (OpenAI-compatible; point at io.net Intelligence / OpenAI / OpenRouter / local) ---
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
LLM_PRICE_IN=0.00015     # per-1k input tokens (for custom endpoints)
LLM_PRICE_OUT=0.0006     # per-1k output tokens

# --- Telegram (blank = channel disabled; UI + internal runs still work) ---
TELEGRAM_BOT_TOKEN=

# --- Observability (optional, P4) ---
MLFLOW_TRACKING_URI=http://localhost:5000
FEATURE_MLFLOW=false

# --- Gated differentiators (P5/P6) ---
FEATURE_A2A=false
FEATURE_DEEPAGENTS=false
FEATURE_DBOS=false

# Console demo login (gates the web console)
AUTH_USERNAME=admin
AUTH_PASSWORD=orchestra
