# Automatic HTTPS for the backend API (frontend is on Vercel). Caddy terminates
# TLS and reverse-proxies the FastAPI backend (REST + WebSocket + /docs). Auth is
# enforced inside the API (email-login bearer token), so there is no proxy gate
# here — the public Vercel frontend calls the API with its token.
138.199.238.92.sslip.io {
    reverse_proxy backend:8000
}
